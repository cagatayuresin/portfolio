---
import Base from "../layouts/Base.astro";
import Icon from "../components/Icon.astro";
---

<Base
  title="404: Page Not Found"
  description="The requested page could not be found on Çağatay Üresin's portfolio."
  canonicalPath="/404"
  robots="noindex, follow"
>
  <section class="not-found">
    <div class="not-found-inner">
      <div class="not-found-copy">
        <span class="not-found-kicker">
          <Icon name="route" size={18} />
          HTTP 404
        </span>
        <h1>
          <span>This route is</span>
          <span>off the map.</span>
        </h1>
        <p>
          The page may have moved, the URL may be outdated, or the deployment
          path you followed no longer exists.
        </p>
        <div class="not-found-actions" aria-label="Helpful links">
          <a href="/" class="not-found-primary">
            <Icon name="sparkles" size={18} />
            Home
          </a>
          <a href="/blog" class="not-found-secondary">
            <Icon name="article" size={18} />
            Blog
          </a>
          <a href="/projects" class="not-found-secondary">
            <Icon name="folders" size={18} />
            Projects
          </a>
        </div>
      </div>

      <div class="not-found-visual" aria-hidden="true">
        <div class="signal-grid"></div>
        <div class="route-line route-line-a"></div>
        <div class="route-line route-line-b"></div>
        <div class="route-node node-a"></div>
        <div class="route-node node-b"></div>
        <div class="route-node node-c"></div>
        <div class="route-node node-d"></div>
        <div class="lost-card">
          <span class="lost-status">route unresolved</span>
          <strong>404</strong>
          <span class="lost-path">/missing-endpoint</span>
        </div>
        <div class="logo-orbit">
          <img src="/logo.png" alt="" />
        </div>
        <div class="terminal-chip chip-a">
          <Icon name="terminal-2" size={18} />
          trace: null
        </div>
        <div class="terminal-chip chip-b">
          <Icon name="search" size={18} />
          index: clear
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .not-found {
    min-height: calc(100vh - 64px);
    display: grid;
    align-items: center;
    padding: 64px 20px;
    overflow-x: hidden;
    background:
      radial-gradient(
        circle at 18% 22%,
        color-mix(in srgb, var(--accent) 13%, transparent),
        transparent 34%
      ),
      radial-gradient(
        circle at 82% 76%,
        color-mix(in srgb, var(--accent) 10%, transparent),
        transparent 32%
      ),
      var(--bg);
  }

  .not-found-inner {
    width: 100%;
    max-width: 1120px;
    min-width: 0;
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(0, 0.92fr) minmax(360px, 1.08fr);
    gap: 44px;
    align-items: center;
  }

  .not-found-copy {
    min-width: 0;
    overflow-wrap: break-word;
  }

  .not-found-kicker {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    min-height: 34px;
    padding: 0 12px;
    border: 1px solid color-mix(in srgb, var(--accent) 28%, var(--border));
    border-radius: 999px;
    background: var(--accent-soft);
    color: var(--accent);
    font-size: 0.82rem;
    font-weight: 700;
  }

  .not-found h1 {
    margin: 22px 0 14px;
    color: var(--text);
    font-size: 3.25rem;
    line-height: 1.04;
    letter-spacing: 0;
  }

  .not-found h1 span {
    display: block;
  }

  .not-found p {
    max-width: 560px;
    margin: 0;
    color: var(--text-soft);
    font-size: 1.08rem;
    line-height: 1.7;
  }

  .not-found-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 28px;
  }

  .not-found-actions a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    min-height: 42px;
    padding: 0 16px;
    border-radius: 10px;
    font-size: 0.94rem;
    font-weight: 700;
    text-decoration: none;
  }

  .not-found-primary {
    border: 1px solid var(--accent);
    background: var(--accent);
    color: #ffffff;
    box-shadow: 0 14px 28px color-mix(in srgb, var(--accent) 22%, transparent);
  }

  .not-found-primary:hover {
    color: #ffffff;
    transform: translateY(-1px);
  }

  :root.dark .not-found-primary,
  :root.dark .not-found-primary:hover {
    color: #0d1117;
  }

  .not-found-secondary {
    border: 1px solid var(--border);
    background: color-mix(in srgb, var(--bg-card) 86%, transparent);
    color: var(--text);
  }

  .not-found-secondary:hover {
    border-color: color-mix(in srgb, var(--accent) 42%, var(--border));
    color: var(--accent);
    transform: translateY(-1px);
  }

  .not-found-visual {
    position: relative;
    min-height: 520px;
    overflow: hidden;
    border: 1px solid var(--border);
    border-radius: 18px;
    background:
      linear-gradient(
        145deg,
        color-mix(in srgb, var(--bg-card) 96%, var(--accent) 4%),
        color-mix(in srgb, var(--bg-soft) 90%, var(--accent) 10%)
      );
    box-shadow: 0 28px 70px rgba(13, 17, 23, 0.12);
  }

  :root.dark .not-found-visual {
    box-shadow: 0 30px 78px rgba(0, 0, 0, 0.34);
  }

  .signal-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(var(--border) 1px, transparent 1px),
      linear-gradient(90deg, var(--border) 1px, transparent 1px);
    background-size: 44px 44px;
    mask-image: radial-gradient(circle at 50% 50%, #000 0 54%, transparent 78%);
    opacity: 0.44;
  }

  .route-line {
    position: absolute;
    width: 440px;
    height: 190px;
    border: 2px dashed color-mix(in srgb, var(--accent) 48%, transparent);
    border-color: color-mix(in srgb, var(--accent) 48%, transparent) transparent
      transparent transparent;
    border-radius: 50%;
  }

  .route-line-a {
    left: 52px;
    top: 110px;
    transform: rotate(18deg);
  }

  .route-line-b {
    right: 38px;
    bottom: 98px;
    transform: rotate(198deg);
  }

  .route-node {
    position: absolute;
    width: 14px;
    height: 14px;
    border-radius: 999px;
    background: var(--accent);
    box-shadow: 0 0 0 8px color-mix(in srgb, var(--accent) 13%, transparent);
  }

  .node-a {
    top: 104px;
    left: 92px;
  }

  .node-b {
    top: 168px;
    right: 118px;
  }

  .node-c {
    bottom: 128px;
    left: 158px;
  }

  .node-d {
    right: 86px;
    bottom: 88px;
  }

  .lost-card {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 272px;
    min-height: 244px;
    transform: translate(-50%, -50%);
    display: grid;
    place-items: center;
    align-content: center;
    gap: 10px;
    border: 1px solid color-mix(in srgb, var(--accent) 34%, var(--border));
    border-radius: 22px;
    background:
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--bg-card) 88%, transparent),
        color-mix(in srgb, var(--bg-soft) 78%, transparent)
      );
    backdrop-filter: blur(14px);
    box-shadow: 0 24px 58px rgba(13, 17, 23, 0.16);
  }

  .lost-card strong {
    color: var(--text);
    font-size: 6rem;
    line-height: 0.92;
    letter-spacing: 0;
  }

  .lost-status,
  .lost-path {
    color: var(--text-soft);
    font-family: var(--mono);
    font-size: 0.76rem;
  }

  .lost-status {
    color: var(--accent);
  }

  .logo-orbit {
    position: absolute;
    left: calc(50% - 34px);
    top: calc(50% - 196px);
    width: 68px;
    height: 68px;
    display: grid;
    place-items: center;
    border: 1px solid color-mix(in srgb, var(--accent) 30%, var(--border));
    border-radius: 18px;
    background: var(--bg-card);
    box-shadow: 0 18px 40px rgba(13, 17, 23, 0.14);
  }

  .logo-orbit img {
    width: 42px;
    height: 42px;
    border-radius: 10px;
  }

  :root.dark .logo-orbit img {
    filter: invert(1);
  }

  .terminal-chip {
    position: absolute;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    min-height: 38px;
    padding: 0 12px;
    border: 1px solid var(--border);
    border-radius: 10px;
    background: color-mix(in srgb, var(--bg-card) 82%, transparent);
    color: var(--text-soft);
    font-family: var(--mono);
    font-size: 0.78rem;
    backdrop-filter: blur(10px);
  }

  .chip-a {
    left: 34px;
    bottom: 34px;
  }

  .chip-b {
    right: 34px;
    top: 34px;
  }

  @media (max-width: 900px) {
    .not-found {
      padding: 44px 18px;
    }

    .not-found-inner {
      grid-template-columns: 1fr;
      gap: 28px;
    }

    .not-found h1 {
      font-size: 2.2rem;
      line-height: 1.12;
    }

    .not-found p {
      font-size: 1rem;
    }

    .not-found-visual {
      min-height: 420px;
    }

    .lost-card {
      width: 236px;
      min-height: 214px;
    }

    .lost-card strong {
      font-size: 4.8rem;
    }
  }

  @media (max-width: 560px) {
    .not-found-inner {
      max-width: 354px;
      margin-left: 0;
      margin-right: auto;
    }

    .not-found-actions a {
      width: 100%;
    }

    .terminal-chip {
      display: none;
    }

    .not-found-visual {
      min-height: 360px;
    }

    .logo-orbit {
      top: 42px;
    }
  }
</style>
